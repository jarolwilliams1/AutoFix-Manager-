</select>
</div>


<div class="mb-3 col-lg-4 col-md-12">
  <label for="pais-marca" class="form-label">PAIS DE ORIGEN</label>
  <input type="email" class="form-control pais-marca" id="pais-marca" placeholder="Opcional" required>
</div>

</section>


<section class="vehiculo-seccion">

      <table class="vehiculos-tabla">
      
  <thead>
    <tr class="tr-th">
      <th>Placa</th>
      <th>Marca</th>
      <th>Modelo</th>
      <th>Año</th>
    <th>Color</th>
     <th>Tipo de vehiculo</th>
      <th>Propietario</th>
      <th>Estado</th>
    <th>Accionnes</th>
   


    </tr>
  </thead>

  <tbody>
    {{#each autores}}
    <tr>
      <td>{{nombreautor}}</td>
      <td>{{correoautor}}</td>
      <td>{{cantidadLibros}}</td>
      <td>{{nombreautor}}</td>
     <td>{{nombreautor}}</td>
      <td>{{correoautor}}</td>
      <td>{{cantidadLibros}}</td>
      <td>{{nombreautor}}</td>
      <td><button>editar</button> <button>eliminar</button></td>    
</tr>
    {{else}}
    <tr>
      <td colspan="4">No hay autores registrados.</td>
    </tr>
    {{/each}}
  </tbody>
</table>

</section>



