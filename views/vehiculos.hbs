<div class="marcas-head">
    <div class="marcas-text-head">
        <h3 class="text-head">Vehículos</h3>
        <p class="marcas-registradas">6 Vehículos registrados</p>
    </div>

    <button>Registar vehículos</button>
</div>

<section class="filtrar-vehiculo container row">

    <div class="mb-3 col-lg-4 col-md-6 col-sm-12">
      <label for="estado-marca" class="form-label">ESTADO</label>
 <select class="form-select estado-marca" id="estado-marca" aria-label="Default select example" required>
  <option selected>Activa</option>
  <option value="Inactiva">Inactiva</option>
</select>
</div>

<div class="mb-3 col-lg-4 col-md-6 col-sm-12">
