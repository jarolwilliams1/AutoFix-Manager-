    </div>
   </div>


    

</section>





<section class="ordenes-seccion">

    <div class="tabla-ordenes-contenedor">
           <div class="tabla-head">
            <div class="tabla-text">
                <h4 class="tabla-text-head">Últimas órdenes de trabajo</h4>
                <p class="recientes">Las 5 más recientes</p>
            </div>

        <a href="" class="link-ver-todas-ordenes">Ver todas </a>

        </div>
      <table class="ordenes-tabla">
    
  <thead>
    <tr class="tr-th">
      <th>N. ORDEN</th>
      <th>VEHICULO</th>
      <th>PLACA</th>
      <th>RECEPCION</th>
      <th>ESTADO</th>
      <th>TOTAL</th>
    <th>    </th>


    </tr>
  </thead>

  <tbody>
    {{#each autores}}
    <tr>
      <td>{{nombreautor}}</td>
      <td>{{correoautor}}</td>
      <td>{{cantidadLibros}}</td>
      <td>{{nombreautor}}</td>
      <td>{{correoautor}}</td>
      <td>{{cantidadLibros}}</td>
      <td><a href=""> Ver detalle</a></td>    
</tr>
    {{else}}
    <tr>
      <td colspan="7">No hay autores registrados.</td>
    </tr>
    {{/each}}
  </tbody>
</table>

    </div>



</section>


